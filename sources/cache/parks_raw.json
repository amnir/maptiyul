"163\\\">08:00-19:00</td>\\n</tr>\\n<tr style=\\\"height: 28px;\\\">\\n<td style=\\\"height: 28px;\\\" width=\\\"188\\\">יולי</td>\\n<td style=\\\"height: 28px;\\\" width=\\\"143\\\">06:00-20:00</td>\\n<td style=\\\"height: 28px;\\\" width=\\\"163\\\">08:00-19:00</td>\\n</tr>\\n<tr style=\\\"height: 28px;\\\">\\n<td style=\\\"height: 28px;\\\" width=\\\"188\\\">אוגוסט</td>\\n<td style=\\\"height: 28px;\\\" width=\\\"143\\\">06:00-20:00</td>\\n<td style=\\\"height: 28px;\\\" width=\\\"163\\\">08:00-19:00</td>\\n</tr>\\n<tr style=\\\"height: 28px;\\\">\\n<td style=\\\"height: 28px;\\\" width=\\\"188\\\">ספטמבר</td>\\n<td style=\\\"height: 28px;\\\" width=\\\"143\\\">06:00-19:00</td>\\n<td style=\\\"height: 28px;\\\" width=\\\"163\\\">08:00-18:00</td>\\n</tr>\\n<tr style=\\\"height: 54px;\\\">\\n<td style=\\\"height: 54px;\\\" width=\\\"188\\\">אוקטובר עד ה-31 לחודש<br />\\nלאחר מכן נסגרת עונת הרחצה</td>\\n<td style=\\\"height: 54px;\\\" width=\\\"143\\\">06:00-19:00</td>\\n<td style=\\\"height: 54px;\\\" width=\\\"163\\\">08:00-18:00</td>\\n</tr>\\n</tbody>\\n</table>\\n<p><strong>חגים ומועדים</strong><strong>:</strong></p>\\n<p><strong> </strong><strong>ערב פסח</strong> – בשעה 15:00 יסתיימו שירותי ההצלה</p>\\n<p><strong>ערב ראש השנה</strong> – בשעה 15:00 יסתיימו שירותי ההצלה</p>\\n<p><strong>ערב יום כיפור</strong> – בשעה 14:00 יסתיימו שירותי ההצלה וייסגרו שערי הכניסה לחוף</p>\\n<h2><strong>חוף ים:</strong></h2>\\n\",\"Months_of_Beach_activity_s\":\"אפריל|מאי|יוני|יולי|אוגוסט|ספטמבר|אוקטובר\",\"Last_entrance_s\":\"\",\"Shop_on_site_s\":\"\"},\"excerpt\":\"<p>נחל אלכסנדר הוא אחד הנחלים החשובים והיפים באזור השרון. לפני שהוא נשפך לים, סמוך לחוף בית ינאי, מלווה את הנחל פארק רחב ידיים, משופע בערכי נוף וטבע: דיונות חול, חורשות אקליפטוסים, שטחי פיקניק ושרידי פעילות אנושית מהעבר. אתר זה פתוח למבקרים ללא תאום מראש שימו לב: הלינה בתחום הגן הלאומי כולל חוף בית ינאי אסורה! [&hellip;]</p>\\n\",\"filters\":{\"caves_f\":false,\"water_access_f\":true,\"blooming_f\":true,\"archaeology_f\":false,\"viewpoint_f\":false,\"challenging_f\":false,\"easy_f\":true,\"moderate_f\":false,\"accessible_f\":true,\"circular_f\":true,\"linear_f\":true,\"half_day_f\":true,\"full_day_f\":true,\"multi_day_f\":false,\"picnic_f\":false,\"trip_f\":true,\"paid_f\":false,\"not_paid_f\":true,\"free_matmon_f\":true,\"not_map_display\":false}},{\"id\":1935,\"title\":\"אתר לאומי הקסטל\",\"link\":\"https://www.parks.org.il/reserve-park/%d7%90%d7%aa%d7%a8-%d7%9c%d7%90%d7%95%d7%9e%d7%99-%d7%94%d7%a7%d7%a1%d7%98%d7%9c/\",\"itm_x\":\"213597\",\"itm_y\":\"633881\",\"in_paid\":null,\"image\":\"https://www.parks.org.il/wp-content/uploads/2017/09/unnamed-file-31.jpg\",\"hours\":{\"Summer_Opening_Hours_s\":\"08:00\",\"Summer_Closing_Hours_s\":\"17:00\",\"Opening_Hours_Summer_Time_Friday\":\"08:00\",\"Closing_Hours_Summer_Time_Friday\":\"16:00\",\"Winter_Opening_Hours_s\":\"08:00\",\"Winter_Closing_Hours_s\":\"16:00\",\"Opening_Hours_Winter_Time_Friday\":\"08:00\",\"Closing_Hours_Winter_Time_Friday\":\"15:00\",\"Opening_hours_of_lifeguard_s\":\"\",\"closing_hours_of_lifeguard_s\":\"\",\"Opening_Tino_On_Pass\":\"08:00\",\"Closing_Time_On_Pas\":\"13:00\",\"Opening_hours_on_Yom_Kippur_s\":\"08:00\",\"closing_hours_on_Yom_Kippur_s\":\"13:00\",\"Special_Opening_hours_s\":\"<h2><strong>שימו לב:</strong></h2>\\n<ul>\\n<li>שעת הכניסה האחרונה לאתר, שעה לפני השעות הרשומות ??</li>\\n<li><strong>הכניסה תותר אך ורק בהצגת אישור &quot;תיאום מועד הביקור&quot; ורק בשעות הנקובות בו</strong></li>\\n</ul>\\n\",\"Months_of_Beach_activity_s\":\"\",\"Last_entrance_s\":\"הכניסה נסגרת שעה לפני השעות הרשומות\",\"Shop_on_site_s\":\"\"},\"excerpt\":\"<p>הקסטל – דרך הערכים בגבעה, המתנשאת מעל הכביש מספר 1 לירושלים, מסופר המאבק על הדרך במלחמת העצמאות ועל נקודת המפנה שהביאה לפריצת הדרך אל עיר. במסלול חווייתי המספר את סיפור הלוחמים באמצעות ערכים מרכזיים שעלו מן הקרבות, כמו: רעות, מנהיגות, נחישות, תוכלו להתנסות בתחנות פעילות וגם ללכת בתוך תעלות קשר ולצפות בסרט ובמיצג הקרב המרגש.</p>\\n\",\"filters\":{\"caves_f\":false,\"water_access_f\":false,\"blooming_f\":false,\"archaeology_f\":true,\"viewpoint_f\":true,\"challenging_f\":false,\"easy_f\":true,\"moderate_f\":true,\"accessible_f\":true,\"circular_f\":true,\"linear_f\":false,\"half_day_f\":true,\"full_day_f\":false,\"multi_day_f\":false,\"picnic_f\":true,\"trip_f\":true,\"paid_f\":true,\"not_paid_f\":false,\"free_matmon_f\":true,\"not_map_display\":false}},{\"id\":1934,\"title\":\"גן לאומי חוף פלמחים\",\"link\":\"https://www.parks.org.il/reserve-park/%d7%92%d7%9f-%d7%9c%d7%90%d7%95%d7%9e%d7%99-%d7%97%d7%95%d7%a3-%d7%a4%d7%9c%d7%9e%d7%97%d7%99%d7%9d/\",\"itm_x\":\"171675\",\"itm_y\":\"648113\",\"in_paid\":null,\"image\":\"https://www.parks.org.il/wp-content/uploads/2017/09/5c655b6f91a49.jpg\",\"hours\":{\"Summer_Opening_Hours_s\":\"\",\"Summer_Closing_Hours_s\":\"\",\"Opening_Hours_Summer_Time_Friday\":\"\",\"Closing_Hours_Summer_Time_Friday\":\"\",\"Winter_Opening_Hours_s\":\"\",\"Winter_Closing_Hours_s\":\"\",\"Opening_Hours_Winter_Time_Friday\":\"\",\"Closing_Hours_Winter_Time_Friday\":\"\",\"Opening_hours_of_lifeguard_s\":\"\",\"closing_hours_of_lifeguard_s\":\"\",\"Opening_Tino_On_Pass\":\"\",\"Closing_Time_On_Pas\":\"\",\"Opening_hours_on_Yom_Kippur_s\":\"\",\"closing_hours_on_Yom_Kippur_s\":\"\",\"Special_Opening_hours_s\":\"<ul>\\n<li>משעה 05:00 עד 22:00</li>\\n<li>כניסת רכבים אחרונה לאתר בשעה 20:00</li>\\n<li>יציאה ואי שהיה באתר בשעה 22:00</li>\\n</ul>\\n<h3>שעות פעילות שרותי הצלה באתר</h3>\\n<table>\\n<thead>\\n<tr>\\n<td width=\\\"169\\\"><strong>חודש</strong></td>\\n<td width=\\\"74\\\"><strong>ימים</strong></td>\\n<td width=\\\"259\\\"><strong>שעות</strong> <strong>פעילות</strong></td>\\n</tr>\\n</thead>\\n<tbody>\\n<tr>\\n<td width=\\\"169\\\">החל מ –15 באפריל</td>\\n<td width=\\\"74\\\">א-ו</td>\\n<td width=\\\"259\\\">08:00-17:00</td>\\n</tr>\\n<tr>\\n<td width=\\\"169\\\"> </td>\\n<td width=\\\"74\\\">שבת</td>\\n<td width=\\\"259\\\">08:00-17:00</td>\\n</tr>\\n<tr>\\n<td width=\\\"169\\\">מאי – 19 ליוני</td>\\n<td width=\\\"74\\\">א-ו</td>\\n<td width=\\\"259\\\">08:00-18:00</td>\\n</tr>\\n<tr>\\n<td width=\\\"169\\\"> </td>\\n<td width=\\\"74\\\">שבת</td>\\n<td width=\\\"259\\\">07:00-19:00</td>\\n</tr>\\n<tr>\\n<td width=\\\"169\\\">מ -20 ליוני ועד סוף אוגוסט</td>\\n<td width=\\\"74\\\">א-ו</td>\\n<td width=\\\"259\\\">08:00-19:00</td>\\n</tr>\\n<tr>\\n<td width=\\\"169\\\"> </td>\\n<td width=\\\"74\\\">שבת</td>\\n<td width=\\\"259\\\">07:00-19:00</td>\\n</tr>\\n<tr>\\n<td width=\\\"169\\\">ספטמבר</td>\\n<td width=\\\"74\\\">א-ו</td>\\n<td width=\\\"259\\\"> 08:00-18:00</td>\\n</tr>\\n<tr>\\n<td width=\\\"169\\\"> </td>\\n<td width=\\\"74\\\">שבת</td>\\n<td width=\\\"259\\\">07:00-18:00</td>\\n</tr>\\n<tr>\\n<td width=\\\"169\\\">אוקטובר</td>\\n<td width=\\\"74\\\">א-ו</td>\\n<td width=\\\"259\\\">08:00-17:00</td>\\n</tr>\\n<tr>\\n<td width=\\\"169\\\">נובמבר 1/11-2/11</td>\\n<td width=\\\"74\\\">שבת</td>\\n<td width=\\\"259\\\">08:00-17:00</td>\\n</tr>\\n</tbody>\\n</table>\\n<h3><strong>חגים ומועדים שעות סגירת שרותי הצלה:</strong></h3>\\n<p><strong>ערב פסח:</strong> 15:00 סגירת החוף לרחצה.</p>\\n<p><strong>ערב ראש השנה:</strong> 15.00 סגירת חוף רחצה.</p>\\n<p><strong> ערב יום כיפור:</strong> 14.00 סגירת חוף רחצה.</p>\\n<h2><strong>הרחצה ללא פיקוח מצילים אסורה ומסוכנת !!</strong></h2>\\n\",\"Months_of_Beach_activity_s\":\"\",\"Last_entrance_s\":\"\",\"Shop_on_site_s\":\"\"},\"excerpt\":\"<p>גן לאומי חוף פלמחים הוא אתר נופש ובילוי ידוע לחובבי חוף הים, אבל הוא גם אתר טבע המשמר חוף טבעי, רכס כורכר חופי וחולות נודדים. בגן הלאומי כלול גם תל יבנה ים. &nbsp; שימו לב: באתר זה לא קיים חניון לילה החוף פתוח ללא צורך בתיאום מראש הנחות והטבות יינתנו בנוכחות הזכאי להם ועם הצגת [&hellip;]</p>\\n\",\"filters\":{\"caves_f\":false,\"water_access_f\":true,\"blooming_f\":true,\"archaeology_f\":false,\"viewpoint_f\":true,\"challenging_f\":false,\"easy_f\":true,\"moderate_f\":false,\"accessible_f\":true,\"circular_f\":true,\"linear_f\":true,\"half_day_f\":true,\"full_day_f\":true,\"multi_day_f\":false,\"picnic_f\":true,\"trip_f\":true,\"paid_f\":true,\"not_paid_f\":false,\"free_matmon_f\":false,\"not_map_display\":false}},{\"id\":1933,\"title\":\"גן לאומי תל אשקלון\",\"link\":\"https://www.parks.org.il/reserve-park/%d7%92%d7%9f-%d7%9c%d7%90%d7%95%d7%9e%d7%99-%d7%90%d7%a9%d7%a7%d7%9c%d7%95%d7%9f/\",\"itm_x\":\"157504\",\"itm_y\":\"619114\",\"in_paid\":null,\"image\":\"https://www.parks.org.il/wp-content/uploads/2017/09/-e1531987122598.jpg\",\"hours\":{\"Summer_Opening_Hours_s\":\"\",\"Summer_Closing_Hours_s\":\"\",\"Opening_Hours_Summer_Time_Friday\":\"\",\"Closing_Hours_Summer_Time_Friday\":\"\",\"Winter_Opening_Hours_s\":\"\",\"Winter_Closing_Hours_s\":\"\",\"Opening_Hours_Winter_Time_Friday\":\"\",\"Closing_Hours_Winter_Time_Friday\":\"\",\"Opening_hours_of_lifeguard_s\":\"\",\"closing_hours_of_lifeguard_s\":\"\",\"Opening_Tino_On_Pass\":\"\",\"Closing_Time_On_Pas\":\"\",\"Opening_hours_on_Yom_Kippur_s\":\"\",\"closing_hours_on_Yom_Kippur_s\":\"\",\"Special_Opening_hours_s\":\"<h4><strong>שעון קיץ (מאי-אוקטובר):</strong></h4>\\n<p><strong>כל השבוע:</strong> 8:00 – 20:00<br />\\nשהיה בגן :   עד השעה 22:00</p>\\n<p>בשעה 22:00  נסגרים שערי היציאה מהגן לאומי.</p>\\n<p>\\nתאורת הלילה אינה לטיול, אלא לפיקניק במקומות נבחרים בלבד.</p>\\n<p><strong>ביום הזכרון וערב יום העצמאות</strong> הגן ישאר סגור</p>\\n<p>&nbsp;</p>\\n<h4><strong>שעון חורף (אוקטובר-אפריל):</strong></h4>\\n<p><strong>כל השבוע:</strong> 16:00-8:00</p>\\n<p>&nbsp;</p>\\n<p>&nbsp;</p>\\n<p>&nbsp;</p>\\n<p>&nbsp;</p>\\n<p><strong>ערב יום כיפור</strong>  13:00-08:00</p>\\n<h4><strong>שעות פעילות חוף הרחצה</strong></h4>\\n<p><strong>אפריל, אוקטובר:</strong> 8:00 &#8211; 17:00<br />\\n<strong>מאי, יוני, ספטמבר:</strong> 8:00 &#8211; 18:00<br />\\n<strong>יולי, אוגוסט:</strong> 8:00 &#8211; 19:00</p>\\n<h4><strong>חניון לילה</strong></h4>\\n<ul>\\n<li> נפתח ללינה <a href=\\\"https://www.parks.org.il/camping/%D7%97%D7%A0%D7%99%D7%95%D7%9F-%D7%9C%D7%99%D7%9C%D7%94-%D7%92%D7%9F-%D7%9C%D7%90%D7%95%D7%9E%D7%99-%D7%90%D7%A9%D7%A7%D7%9C%D7%95%D7%9F/#8\\\" target=\\\"_blank\\\" rel=\\\"noopener\\\"><strong>&#8211; להרשמה לחצו כאן </strong></a></li>\\n<li>אין אפשרות ללינה בקרוואן</li>\\n</ul>\\n\",\"Months_of_Beach_activity_s\":\"\",\"Last_entrance_s\":\"\",\"Shop_on_site_s\":\"\"},\"excerpt\":\"<p>הגן הלאומי משלב אתר עתיקות מרתק, פארק לבילוי בחיק הטבע וחוף רחצה נהדר. באתר נחשפה עיר מהתקופה הכנענית התיכונה, מוקפת סוללה אדירה ובה השער הקדום בעולם שנושא קשת בנויה. חלקו הדרומי של הגן הלאומי משמר את עולם הצומח והחי של חולות מישור החוף. שימו לב: אין צורך לתאם ביקור לתל אשקלון. הכניסה על בסיס מקום [&hellip;]</p>\\n\",\"filters\":{\"caves_f\":false,\"water_access_f\":true,\"blooming_f\":true,\"archaeology_f\":true,\"viewpoint_f\":true,\"challenging_f\":false,\"easy_f\":true,\"moderate_f\":false,\"accessible_f\":true,\"circular_f\":true,\"linear_f\":false,\"half_day_f\":true,\"full_day_f\":false,\"multi_day_f\":false,\"picnic_f\":true,\"trip_f\":true,\"paid_f\":true,\"not_paid_f\":false,\"free_matmon_f\":true,\"not_map_display\":false}},{\"id\":1932,\"title\":\"גן לאומי חוף השרון\",\"link\":\"https://www.parks.org.il/reserve-park/%d7%92%d7%9f-%d7%9c%d7%90%d7%95%d7%9e%d7%99-%d7%97%d7%95%d7%a3-%d7%94%d7%a9%d7%a8%d7%95%d7%9f/\",\"itm_x\":\"183111\",\"itm_y\":\"680795\",\"in_paid\":null,\"image\":\"https://www.parks.org.il/wp-content/uploads/2017/09/gan-leumi-chof-asharon-doron-nisim-e1525941892662.jpg\",\"hours\":{\"Summer_Opening_Hours_s\":\"\",\"Summer_Closing_Hours_s\":\"\",\"Opening_Hours_Summer_Time_Friday\":\"\",\"Closing_Hours_Summer_Time_Friday\":\"\",\"Winter_Opening_Hours_s\":\"\",\"Winter_Closing_Hours_s\":\"\",\"Opening_Hours_Winter_Time_Friday\":\"\",\"Closing_Hours_Winter_Time_Friday\":\"\",\"Opening_hours_of_lifeguard_s\":\"\",\"closing_hours_of_lifeguard_s\":\"\",\"Opening_Tino_On_Pass\":\"\",\"Closing_Time_On_Pas\":\"\",\"Opening_hours_on_Yom_Kippur_s\":\"\",\"closing_hours_on_Yom_Kippur_s\":\"\",\"Special_Opening_hours_s\":\"<p>הגן הלאומי פתוח בשעות היום, מהזריחה עד השקיעה. השהייה בו בלילה אסורה.</p>\\n<h3><strong>הנחיות בטיחות למטיילים בחוף השרון:</strong></h3>\\n<ul>\\n<li><strong>חל איסור להתקרב לשפת המצוק ולהימצא בקרבתו! </strong>לאחרונה התרחשו נפילות של חלקים ממצוק הכורכר בחופי הים התיכון, הציבור מתבקש להימנע מלהתקרב למצוק בכל צורה שהיא, בין עם על החוף או על ראש המצוק. די בהתמוטטות אחת בכדי לגרום למוות או לפציעה חמורה.</li>\\n<li>מחשש להתמוטטות מצוק הכורכר, חל איסור על <strong>שהייה והליכה על חוף הים</strong> בכל חלקי הגן הלאומי למעט בחוף הרחצה המוכרז.</li>\\n<li><strong>הכניסה למים</strong> מותרת בחוף הרחצה המוכרז בעונת הרחצה ובשעות פעילות שירותי ההצלה בלבד.</li>\\n<li>על מנת לשמור על החי, הצומח והדומם ועל בטיחות המטיילים, ההליכה מותרת על <strong>השבילים המסומנים בלבד</strong>.</li>\\n<li>אסורה הכנסת <strong>כלי רכב</strong> לרבות אופנועים, טרקטורונים ורכבים חשמליים לתחום הגן הלאומי.</li>\\n<li>הטיול בשמורה מותר <strong>בהליכה בלבד</strong>, אין לרכוב על גבי אופניים או סוסים בתחום הגן הלאומי.</li>\\n<li>אסורה <strong>הבערת אש</strong> בכל שטחי הגן הלאומי.</li>\\n<li>אין להכניס <strong>כלבים</strong> לשטח הגן הלאומי.</li>\\n<li>כדי לאפשר לחיות הבר לקיים את שגרת חייהם, השהייה בגן בשעות החשיכה <strong>אסורה</strong>.</li>\\n</ul>\\n<p>&nbsp;</p>\\n\",\"Months_of_Beach_activity_s\":\"ינואר|פברואר|מרץ|אפריל|מאי|יוני|יולי|אוגוסט|ספטמבר|אוקטובר|נובמבר|דצמבר\",\"Last_entrance_s\":\"\",\"Shop_on_site_s\":\"\"},\"excerpt\":\"<p>צוקי כורכר נישאים לאורך החוף בין נתניה להרצליה ובעורפם צמחייה שופעת, תצפיות נוף, שבילי הליכה, פריחה עונתית ואף אוכלוסיית צבאים. גם החוף למרגלות המצוקים כלול בגן הלאומי. שימו לב סכנת קריסה במצוק הכורכר אין להתקרב לשפת המצוק או למרגלותיו חל איסור על שהייה והליכה על חוף הים בכל חלקי הגן הלאומי למעט בחוף הרחצה המוכרז, [&hellip;]</p>\\n\",\"filters\":{\"caves_f\":false,\"water_access_f\":false,\"blooming_f\":true,\"archaeology_f\":false,\"viewpoint_f\":false,\"challenging_f\":false,\"easy_f\":true,\"moderate_f\":false,\"accessible_f\":false,\"circular_f\":false,\"linear_f\":false,\"half_day_f\":true,\"full_day_f\":true,\"multi_day_f\":false,\"picnic_f\":false,\"trip_f\":true,\"paid_f\":false,\"not_paid_f\":true,\"free_matmon_f\":true,\"not_map_display\":false}},{\"id\":1928,\"title\":\"שמורת טבע מערת הנטיפים\",\"link\":\"https://www.parks.org.il/reserve-park/%d7%a9%d7%9e%d7%95%d7%a8%d7%aa-%d7%98%d7%91%d7%a2-%d7%9e%d7%a2%d7%a8%d7%aa-%d7%94%d7%a0%d7%98%d7%99%d7%a4%d7%99%d7%9d/\",\"itm_x\":\"202380\",\"itm_y\":\"629251\",\"in_paid\":null,\"image\":\"https://www.parks.org.il/wp-content/uploads/2017/09/netifit-gavriela.jpg\",\"hours\":{\"Summer_Opening_Hours_s\":\"\",\"Summer_Closing_Hours_s\":\"\",\"Opening_Hours_Summer_Time_Friday\":\"\",\"Closing_Hours_Summer_Time_Friday\":\"\",\"Winter_Opening_Hours_s\":\"\",\"Winter_Closing_Hours_s\":\"\",\"Opening_Hours_Winter_Time_Friday\":\"\",\"Closing_Hours_Winter_Time_Friday\":\"\",\"Opening_hours_of_lifeguard_s\":\"\",\"closing_hours_of_lifeguard_s\":\"\",\"Opening_Tino_On_Pass\":\"\",\"Closing_Time_On_Pas\":\"13:00\",\"Opening_hours_on_Yom_Kippur_s\":\"\",\"closing_hours_on_Yom_Kippur_s\":\"\",\"Special_Opening_hours_s\":\"<h3>שעון קיץ:</h3>\\n<p>בימים א'- ה'  ושבת <strong>ניתן להיכנס לשמורה בין השעות 8:00 ועד השעה 16:00 </strong>האתר נסגר בשעה 17:00 .</p>\\n<p>בימי שישי וערבי חג <strong>ניתן להיכנס לשמורה בין השעות 8:00 ועד השעה 15:00</strong> האתר נסגר בשעה 16:00</p>\\n<h3>שעון חורף:</h3>\\n<p>בימים א'- ה'  ושבת <strong>ניתן להיכנס לשמורה בין השעות 8:00 ועד השעה 15:00</strong> האתר נסגר בשעה 16:00.</p>\\n<p>בימי שישי וערבי חג <strong>ניתן להיכנס לשמורה בין השעות 8:00 ועד השעה 14:00</strong> האתר נסגר בשעה 15:00.</p>\\n<p>בערב ראש השנה, ערב יום הכיפורים וערב פסח ניתן להיכנס לשמורה עד השעה 12:00 האתר נסגר בשעה 13:00.</p>\\n<h2><strong>שימו לב: </strong></h2>\\n<ul>\\n<li>הסיור עצמי וכולל סרט. ללא הדרכה.</li>\\n<li>יש להגיע לאתר כ- 30 דקות לפני מועד הסיור</li>\\n<li>אם נרשמתם מראש, הגעתם לאתר ואין בו מקום פנוי &#8211; תתבקשו להציג בכניסה את האישור על &quot;<strong>תיאום מועד הביקור</strong>&quot; כדי להיכנס.</li>\\n</ul>\\n\",\"Months_of_Beach_activity_s\":\"\",\"Last_entrance_s\":\"הכניסה לשמורה נסגרת שעה לפני השעות הרשומות\",\"Shop_on_site_s\":\"\"},\"excerpt\":\"<p>בשמורה שטח חורש טבעי נרחב ומערת הנטיפים הגדולה והיפה במערות הארץ. הכניסה לבטן האדמה מאפשרת ביקור בעולם אגדות קסום ומופלא של פסלי אבן מעשה ידי הטבע. נטיפים וזקיפים בשלל צורות מעוררים את דמיונם של גדולים וקטנים ומבטיחים חוויה מרהיבה. נרשמת &#8211; נכנסת! בשל עומס מבקרים, הכניסה למערת הנטיפים תתאפשר רק למי שתאמו ביקור מראש. לתיאום [&hellip;]</p>\\n\",\"filters\":{\"caves_f\":true,\"water_access_f\":false,\"blooming_f\":false,\"archaeology_f\":false,\"viewpoint_f\":false,\"challenging_f\":false,\"easy_f\":true,\"moderate_f\":false,\"accessible_f\":true,\"circular_f\":true,\"linear_f\":false,\"half_day_f\":true,\"full_day_f\":false,\"multi_day_f\":false,\"picnic_f\":true,\"trip_f\":true,\"paid_f\":true,\"not_paid_f\":false,\"free_matmon_f\":true,\"not_map_display\":false}},{\"id\":1926,\"title\":\"גן לאומי ירקון\",\"link\":\"https://www.parks.org.il/reserve-park/yarkon/\",\"itm_x\":\"\",\"itm_y\":\"\",\"in_paid\":null,\"image\":\"https://www.parks.org.il/wp-content/uploads/2017/09/16-e1512552025368.jpg\",\"hours\":{\"Summer_Opening_Hours_s\":\"08:00\",\"Summer_Closing_Hours_s\":\"17:00\",\"Opening_Hours_Summer_Time_Friday\":\"08:00\",\"Closing_Hours_Summer_Time_Friday\":\"16:00\",\"Winter_Opening_Hours_s\":\"08:00\",\"Winter_Closing_Hours_s\":\"16:00\",\"Opening_Hours_Winter_Time_Friday\":\"08:00\",\"Closing_Hours_Winter_Time_Friday\":\"15:00\",\"Opening_hours_of_lifeguard_s\":\"\",\"closing_hours_of_lifeguard_s\":\"\",\"Opening_Tino_On_Pass\":\"08:00\",\"Closing_Time_On_Pas\":\"13:00\",\"Opening_hours_on_Yom_Kippur_s\":\"08:00\",\"closing_hours_on_Yom_Kippur_s\":\"13:00\",\"Special_Opening_hours_s\":\"<p>&nbsp;</p>\\n<p>&nbsp;</p>\\n<p>&nbsp;</p>\\n\",\"Months_of_Beach_activity_s\":\"\",\"Last_entrance_s\":\"הכניסה לגן נסגרת שעה לפני השעות הרשומות\",\"Shop_on_site_s\":\"\"},\"excerpt\":\"<p>גן לאומי ירקון משתרע לאורך נחל הירקון ומעיינותיו, ובתוכו שני מתחמים שונים זה מזה. בכרטיס כניסה אחד ניתן להיכנס לשניהם, אך לכל מתחם רישום נפרד. כדאי להחליט קודם איפה מבקרים, להירשם ולהגיע למקום הנכון. מה בכל מתחם? מתחם תל אפק (אנטיפטריס) &#8211; מציע שילוב של מורשת ומים. בראש התל מבצר עות'מאני שמשקיף על מישור החוף, [&hellip;]</p>\\n\",\"filters\":{\"caves_f\":false,\"water_access_f\":true,\"blooming_f\":true,\"archaeology_f\":true,\"viewpoint_f\":false,\"challenging_f\":false,\"easy_f\":true,\"moderate_f\":false,\"accessible_f\":true,\"circular_f\":true,\"linear_f\":true,\"half_day_f\":true,\"full_day_f\":false,\"multi_day_f\":false,\"picnic_f\":true,\"trip_f\":true,\"paid_f\":true,\"not_paid_f\":false,\"free_matmon_f\":true,\"not_map_display\":false}},{\"id\":1925,\"title\":\"גן לאומי עין חמד\",\"link\":\"https://www.parks.org.il/reserve-park/%d7%92%d7%9f-%d7%9c%d7%90%d7%95%d7%9e%d7%99-%d7%a2%d7%99%d7%9f-%d7%97%d7%9e%d7%93/\",\"itm_x\":\"212131\",\"itm_y\":\"634026\",\"in_paid\":null,\"image\":\"https://www.parks.org.il/wp-content/uploads/2017/09/סלייד-עין-חמד.jpg\",\"hours\":{\"Summer_Opening_Hours_s\":\"08:00\",\"Summer_Closing_Hours_s\":\"17:00\",\"Opening_Hours_Summer_Time_Friday\":\"08:00\",\"Closing_Hours_Summer_Time_Friday\":\"16:00\",\"Winter_Opening_Hours_s\":\"08:00\",\"Winter_Closing_Hours_s\":\"16:00\",\"Opening_Hours_Winter_Time_Friday\":\"08:00\",\"Closing_Hours_Winter_Time_Friday\":\"15:00\",\"Opening_hours_of_lifeguard_s\":\"\",\"closing_hours_of_lifeguard_s\":\"\",\"Opening_Tino_On_Pass\":\"08:00\",\"Closing_Time_On_Pas\":\"13:00\",\"Opening_hours_on_Yom_Kippur_s\":\"08:00\",\"closing_hours_on_Yom_Kippur_s\":\"13:00\",\"Special_Opening_hours_s\":\"<h2><strong>שימו לב:</strong></h2>\\n<ul>\\n<li>אם נרשמתם מראש, הגעתם לאתר ואין בו מקום פנוי &#8211; תתבקשו להציג בכניסה את האישור על &quot;<strong>תיאום מועד הביקור</strong>&quot; כדי להיכנס.</li>\\n</ul>\\n\",\"Months_of_Beach_activity_s\":\"\",\"Last_entrance_s\":\"הכניסה לגן נסגרת שעה לפני השעות הרשומות\",\"Shop_on_site_s\":\"\"},\"excerpt\":\"<p>פנינת טבע במרכז הארץ בפיתולי הדרך לירושלים. בפינה נסתרת וקסומה, שוכן הגן הלאומי עין חמד. בתוך מרחבים מוריקים ומשובבי נפש. בין שפעת המים של נחל כסלון, בין התעלות והברכות, ובינות שבילי הטיול המוצלים, ניצבת פנינה היסטורית – &quot;אקווה בלה&quot; (המים היפים). חווה חקלאית צלבנית שהשתמרה יפה ומספרת את סיפורו של המקום. נרשמת &#8211; נכנסת! הכניסה [&hellip;]</p>\\n\",\"filters\":{\"caves_f\":false,\"water_access_f\":true,\"blooming_f\":true,\"archaeology_f\":true,\"viewpoint_f\":false,\"challenging_f\":false,\"easy_f\":true,\"moderate_f\":false,\"accessible_f\":true,\"circular_f\":true,\"linear_f\":false,\"half_day_f\":true,\"full_day_f\":false,\"multi_day_f\":false,\"picnic_f\":true,\"trip_f\":true,\"paid_f\":true,\"not_paid_f\":false,\"free_matmon_f\":true,\"not_map_display\":false}},{\"id\":1924,\"title\":\"יחידת הדרכה מחוז מרכז\",\"link\":\"https://www.parks.org.il/reserve-park/%d7%99%d7%97%d7%99%d7%93%d7%aa-%d7%94%d7%93%d7%a8%d7%9b%d7%94-%d7%9e%d7%97%d7%95%d7%96-%d7%9e%d7%a8%d7%9b%d7%96/\",\"itm_x\":\"\",\"itm_y\":\"\",\"in_paid\":null,\"image\":\"https://www.parks.org.il/wp-content/uploads/2017/09/unnamed-file-27.jpg\",\"hours\":{\"Summer_Opening_Hours_s\":\"\",\"Summer_Closing_Hours_s\":\"\",\"Opening_Hours_Summer_Time_Friday\":\"\",\"Closing_Hours_Summer_Time_Friday\":\"\",\"Winter_Opening_Hours_s\":\"\",\"Winter_Closing_Hours_s\":\"\",\"Opening_Hours_Winter_Time_Friday\":\"\",\"Closing_Hours_Winter_Time_Friday\":\"\",\"Opening_hours_of_lifeguard_s\":\"\",\"closing_hours_of_lifeguard_s\":\"\",\"Opening_Tino_On_Pass\":\"\",\"Closing_Time_On_Pas\":\"\",\"Opening_hours_on_Yom_Kippur_s\":\"\",\"closing_hours_on_Yom_Kippur_s\":\"\",\"Special_Opening_hours_s\":\"\",\"Months_of_Beach_activity_s\":\"\",\"Last_entrance_s\":\"\",\"Shop_on_site_s\":\"\"},\"excerpt\":\"<p>יחידת ההדרכה של מחוז מרכז, שוכנת בגן לאומי אשקלון. היחידה מתמקצעת בהדרכות אתריות ונושאיות בגנים לאומיים, שמורות טבע ושטחים פתוחים במרכז הארץ</p>\\n\",\"filters\":{\"caves_f\":false,\"water_access_f\":false,\"blooming_f\":false,\"archaeology_f\":false,\"viewpoint_f\":false,\"challenging_f\":false,\"easy_f\":false,\"moderate_f\":false,\"accessible_f\":false,\"circular_f\":false,\"linear_f\":false,\"half_day_f\":false,\"full_day_f\":false,\"multi_day_f\":false,\"picnic_f\":false,\"trip_f\":true,\"paid_f\":false,\"not_paid_f\":false,\"free_matmon_f\":false,\"not_map_display\":false}},{\"id\":1918,\"title\":\"גן לאומי גן השלושה (הסחנה)\",\"link\":\"https://www.parks.org.il/reserve-park/%d7%92%d7%9f-%d7%9c%d7%90%d7%95%d7%9e%d7%99-%d7%92%d7%9f-%d7%94%d7%a9%d7%9c%d7%95%d7%a9%d7%94-%d7%94%d7%a1%d7%97%d7%a0%d7%94/\",\"itm_x\":\"242124\",\"itm_y\":\"712594\",\"in_paid\":null,\"image\":\"https://www.parks.org.il/wp-content/uploads/2025/12/WhatsApp-Image-2025-12-11-at-08.52.26-1.jpeg\",\"hours\":{\"Summer_Opening_Hours_s\":\"08:00\",\"Summer_Closing_Hours_s\":\"17:00\",\"Opening_Hours_Summer_Time_Friday\":\"08:00\",\"Closing_Hours_Summer_Time_Friday\":\"16:00\",\"Winter_Opening_Hours_s\":\"08:00\",\"Winter_Closing_Hours_s\":\"16:00\",\"Opening_Hours_Winter_Time_Friday\":\"08:00\",\"Closing_Hours_Winter_Time_Friday\":\"15:00\",\"Opening_hours_of_lifeguard_s\":\"\",\"closing_hours_of_lifeguard_s\":\"\",\"Opening_Tino_On_Pass\":\"08:00\",\"Closing_Time_On_Pas\":\"13:00\",\"Opening_hours_on_Yom_Kippur_s\":\"08:00\",\"closing_hours_on_Yom_Kippur_s\":\"13:00\",\"Special_Opening_hours_s\":\"<p><strong>בחג ובחול המועד סוכות: </strong>אין שינוי בשעות הפעילות</p>\\n<p><strong>שעות פתיחת אתר &quot;חומה ומגדל&quot; והמוזיאון לארכיאולוגיה:</strong><br />\\nא' – ה' ושבת בשעות ‎ 10:00 – 14:00 <a href=\\\"https://www.parks.org.il/reserve-park/shlosha/\\\" target=\\\"_blank\\\" rel=\\\"noopener\\\">לפרטים נוספים לחצו כאן&gt;&gt; </a></p>\\n<p><strong>בליל הסדר 2025</strong>: כניסה עד 14:00, סגירה ב-15:00</p>\\n<p>&nbsp;</p>\\n\",\"Months_of_Beach_activity_s\":\"\",\"Last_entrance_s\":\"הכניסה לגן נסגרת שעה לפני השעות הרשומות\",\"Shop_on_site_s\":\"\"},\"excerpt\":\"<p>פארק מים מפורסם במערב עמק המעיינות (עמק בית שאן). ייחודו של גן השלושה במעיינותיו החמימים ובבריכות הרחצה הטבעיות שבו. בתחומו יש גם מוזיאון ארכיאולוגי ושחזור אתר ההתיישבות ההיסטורי של קיבוץ תל עמל, שעלה על הקרקע ופתח את תקופת יישובי חומה ומגדל. שימו לב: הכניסה לגן השלושה/הסחנה הינה על בסיס מקום פנוי. אין צורך ברישום, מומלץ [&hellip;]</p>\\n\",\"filters\":{\"caves_f\":false,\"water_access_f\":true,\"blooming_f\":false,\"archaeology_f\":true,\"viewpoint_f\":false,\"challenging_f\":false,\"easy_f\":true,\"moderate_f\":false,\"accessible_f\":true,\"circular_f\":true,\"linear_f\":false,\"half_day_f\":true,\"full_day_f\":false,\"multi_day_f\":false,\"picnic_f\":true,\"trip_f\":true,\"paid_f\":true,\"not_paid_f\":false,\"free_matmon_f\":false,\"not_map_display\":false}},{\"id\":1916,\"title\":\"גן לאומי כורסי\",\"link\":\"https://www.parks.org.il/reserve-park/%d7%92%d7%9f-%d7%9c%d7%90%d7%95%d7%9e%d7%99-%d7%9b%d7%95%d7%a8%d7%a1%d7%99/\",\"itm_x\":\"261173\",\"itm_y\":\"748067\",\"in_paid\":null,\"image\":\"https://www.parks.org.il/wp-content/uploads/2019/11/30707844_915556155288634_3076355134184226816_n.jpg\",\"hours\":{\"Summer_Opening_Hours_s\":\"08:00\",\"Summer_Closing_Hours_s\":\"17:00\",\"Opening_Hours_Summer_Time_Friday\":\"08:00\",\"Closing_Hours_Summer_Time_Friday\":\"16:00\",\"Winter_Opening_Hours_s\":\"08:00\",\"Winter_Closing_Hours_s\":\"16:00\",\"Opening_Hours_Winter_Time_Friday\":\"08:00\",\"Closing_Hours_Winter_Time_Friday\":\"15:00\",\"Opening_hours_of_lifeguard_s\":\"\",\"closing_hours_of_lifeguard_s\":\"\",\"Opening_Tino_On_Pass\":\"08:00\",\"Closing_Time_On_Pas\":\"13:00\",\"Opening_hours_on_Yom_Kippur_s\":\"08:00\",\"closing_hours_on_Yom_Kippur_s\":\"13:00\",\"Special_Opening_hours_s\":\"<h2><strong>שימו לב:</strong></h2>\\n<p>אם נרשמתם מראש, הגעתם לאתר ואין בו מקום פנוי &#8211; תתבקשו להציג בכניסה את האישור על &quot;<strong>תיאום מועד הביקור</strong>&quot; כדי להיכנס.</p>\\n\",\"Months_of_Beach_activity_s\":\"\",\"Last_entrance_s\":\"הכניסה לגן נסגרת שעה לפני השעות הרשומות\",\"Shop_on_site_s\":\"\"},\"excerpt\":\"<p>גן לאומי כורסי משמר שרידים מרשימים של מנזר וכנסייה מהתקופה הביזנטית. על פי המסורת הנוצרית במקום זה התרחש נס החזירים הנזכר בברית החדשה. נרשמת &#8211; נכנסת! רישום מראש במערכת תיאום הביקור מבטיח לך מקום באתר ובמועד שאליו נרשמת, ומאפשר קבלת מידע ועדכונים רלוונטיים לביקור המתוכנן. לתיאום ביקור &#8211; לחצו כאן &nbsp;</p>\\n\",\"filters\":{\"caves_f\":false,\"water_access_f\":false,\"blooming_f\":false,\"archaeology_f\":true,\"viewpoint_f\":false,\"challenging_f\":false,\"easy_f\":true,\"moderate_f\":false,\"accessible_f\":true,\"circular_f\":true,\"linear_f\":false,\"half_day_f\":true,\"full_day_f\":false,\"multi_day_f\":false,\"picnic_f\":true,\"trip_f\":true,\"paid_f\":true,\"not_paid_f\":false,\"free_matmon_f\":true,\"not_map_display\":false}},{\"id\":1915,\"title\":\"גן לאומי ברעם\",\"link\":\"https://www.parks.org.il/reserve-park/%d7%92%d7%9f-%d7%9c%d7%90%d7%95%d7%9e%d7%99-%d7%91%d7%a8%d7%a2%d7%9d/\",\"itm_x\":\"239139\",\"itm_y\":\"772034\",\"in_paid\":null,\"image\":\"https://www.parks.org.il/wp-content/uploads/2018/01/unnamed-file-2-e1538557667707.jpg\",\"hours\":{\"Summer_Opening_Hours_s\":\"08:00\",\"Summer_Closing_Hours_s\":\"17:00\",\"Opening_Hours_Summer_Time_Friday\":\"08:00\",\"Closing_Hours_Summer_Time_Friday\":\"16:00\",\"Winter_Opening_Hours_s\":\"08:00\",\"Winter_Closing_Hours_s\":\"16:00\",\"Opening_Hours_Winter_Time_Friday\":\"08:00\",\"Closing_Hours_Winter_Time_Friday\":\"15:00\",\"Opening_hours_of_lifeguard_s\":\"\",\"closing_hours_of_lifeguard_s\":\"\",\"Opening_Tino_On_Pass\":\"08:00\",\"Closing_Time_On_Pas\":\"13:00\",\"Opening_hours_on_Yom_Kippur_s\":\"08:00\",\"closing_hours_on_Yom_Kippur_s\":\"13:00\",\"Special_Opening_hours_s\":\"<h2><strong>שימו לב:</strong></h2>\\n<p>אם נרשמתם מראש, הגעתם לאתר ואין בו מקום פנוי &#8211; תתבקשו להציג בכניסה את האישור על &quot;<strong>תיאום מועד הביקור</strong>&quot; כדי להיכנס.</p>\\n\",\"Months_of_Beach_activity_s\":\"\",\"Last_entrance_s\":\"הכניסה לגן נסגרת שעה לפני השעות הרשומות\",\"Shop_on_site_s\":\"\"},\"excerpt\":\"<p>גן לאומי ברעם מציג מבנה מפואר של בית כנסת מימי התלמוד, במצב השתמרות נדיר. ליופיו של המבנה הקדום מצטרפים הנופים של שמורת הטבע יער ברעם ושל הרי הגליל. נרשמת &#8211; נכנסת! רישום מראש במערכת תיאום הביקור מבטיח לך מקום באתר ובמועד שאליו נרשמת, ומאפשר קבלת מידע ועדכונים רלוונטיים לביקור המתוכנן. לתיאום ביקור &#8211; לחצו כאן [&hellip;]</p>\\n\",\"filters\":{\"caves_f\":false,\"water_access_f\":false,\"blooming_f\":false,\"archaeology_f\":true,\"viewpoint_f\":false,\"challenging_f\":false,\"easy_f\":true,\"moderate_f\":false,\"accessible_f\":true,\"circular_f\":true,\"linear_f\":false,\"half_day_f\":true,\"full_day_f\":true,\"multi_day_f\":false,\"picnic_f\":true,\"trip_f\":true,\"paid_f\":true,\"not_paid_f\":false,\"free_matmon_f\":true,\"not_map_display\":false}},{\"id\":1914,\"title\":\"פארק הכרמל\",\"link\":\"https://www.parks.org.il/reserve-park/%d7%a4%d7%90%d7%a8%d7%a7-%d7%94%d7%9b%d7%a8%d7%9e%d7%9c/\",\"itm_x\":\"201733\",\"itm_y\":\"736987\",\"in_paid\":null,\"image\":\"https://www.parks.org.il/wp-content/uploads/2017/08/DSC_8972-e1512906382180.jpg\",\"hours\":{\"Summer_Opening_Hours_s\":\"\",\"Summer_Closing_Hours_s\":\"\",\"Opening_Hours_Summer_Time_Friday\":\"\",\"Closing_Hours_Summer_Time_Friday\":\"\",\"Winter_Opening_Hours_s\":\"\",\"Winter_Closing_Hours_s\":\"\",\"Opening_Hours_Winter_Time_Friday\":\"\",\"Closing_Hours_Winter_Time_Friday\":\"\",\"Opening_hours_of_lifeguard_s\":\"\",\"closing_hours_of_lifeguard_s\":\"\",\"Opening_Tino_On_Pass\":\"\",\"Closing_Time_On_Pas\":\"\",\"Opening_hours_on_Yom_Kippur_s\":\"\",\"closing_hours_on_Yom_Kippur_s\":\"\",\"Special_Opening_hours_s\":\"<p>הפארק פתוח למטיילים ולמבקרים בחניונים כל השבוע.<br />\\nקבוצות, אירועים, פעילות מסחרית: יש לתאם מול משרד פארק הכרמל‎ – 04-8228983 (כרוך בתשלום)</p>\\n\",\"Months_of_Beach_activity_s\":\"\",\"Last_entrance_s\":\"\",\"Shop_on_site_s\":\"\"},\"excerpt\":\"<p>ההר הירוק כל ימות השנה &quot;ראשך עלייך ככרמל&quot;, אמר משורר שיר השירים, ואמנם מאז ימי קדם הכרמל הוא סמל ליופי. החורש ירוק-העד, נופי הפרא מרהיבי העין, אתרי עבר חשובים ועולם עשיר של חי וצומח הפכו את הכרמל למרחב טבע ומורשת שאין שני לו בישראל. מרושת בשבילי טיול, בחניונים ובמצפורים. שימו לב: אסור להדליק מדורות בכל [&hellip;]</p>\\n\",\"filters\":{\"caves_f\":false,\"water_access_f\":false,\"blooming_f\":true,\"archaeology_f\":false,\"viewpoint_f\":false,\"challenging_f\":false,\"easy_f\":true,\"moderate_f\":true,\"accessible_f\":true,\"circular_f\":false,\"linear_f\":false,\"half_day_f\":true,\"full_day_f\":true,\"multi_day_f\":false,\"picnic_f\":false,\"trip_f\":true,\"paid_f\":false,\"not_paid_f\":true,\"free_matmon_f\":true,\"not_map_display\":false}},{\"id\":1913,\"title\":\"גן לאומי ציפורי\",\"link\":\"https://www.parks.org.il/reserve-park/%d7%92%d7%9f-%d7%9c%d7%90%d7%95%d7%9e%d7%99-%d7%a6%d7%99%d7%a4%d7%95%d7%a8%d7%99/\",\"itm_x\":\"226941\",\"itm_y\":\"739554\",\"in_paid\":null,\"image\":\"https://www.parks.org.il/wp-content/uploads/2017/08/zipori-doron-nisim-e1512905651275.jpg\",\"hours\":{\"Summer_Opening_Hours_s\":\"08:00\",\"Summer_Closing_Hours_s\":\"17:00\",\"Opening_Hours_Summer_Time_Friday\":\"08:00\",\"Closing_Hours_Summer_Time_Friday\":\"16:00\",\"Winter_Opening_Hours_s\":\"08:00\",\"Winter_Closing_Hours_s\":\"16:00\",\"Opening_Hours_Winter_Time_Friday\":\"08:00\",\"Closing_Hours_Winter_Time_Friday\":\"15:00\",\"Opening_hours_of_lifeguard_s\":\"\",\"closing_hours_of_lifeguard_s\":\"\",\"Opening_Tino_On_Pass\":\"08:00\",\"Closing_Time_On_Pas\":\"13:00\",\"Opening_hours_on_Yom_Kippur_s\":\"08:00\",\"closing_hours_on_Yom_Kippur_s\":\"13:00\",\"Special_Opening_hours_s\":\"<h2><strong>שימו לב:</strong></h2>\\n<ul>\\n<li>התצפית על פסיפס אורפיאוס בגן לאומי ציפורי סגורה, לצורך עבודות בטיחות ותחזוקה.</li>\\n<li>מאגר המים פתוח חלקית בלבד.</li>\\n<li>ביום הזכרון לחללי צהל וביום השואה, אין להדליק מצלה/מנגל בשטח הגן הלאומי.</li>\\n<li>אין להכניס לאתר מערכת הגברה מכל סוג,  ללא תיאום מראש.</li>\\n<li>אם נרשמתם מראש, הגעתם לאתר ואין בו מקום פנוי &#8211; תתבקשו להציג בכניסה את האישור על &quot;<strong>תיאום מועד הביקור</strong>&quot; כדי להיכנס.</li>\\n</ul>\\n\",\"Months_of_Beach_activity_s\":\"\",\"Last_entrance_s\":\"הכניסה לגן נסגרת שעה לפני השעות הרשומות\",\"Shop_on_site_s\":\"\"},\"excerpt\":\"<p>ציפורי הייתה בעבר בירת הגליל, בה ישבה הסנהדרין ובה נחתמה המשנה. בציפורי חיה אוכלוסייה מעורבת, ונותרו בה שרידים של עשרות פסיפסים יפהפיים מהתקופה הרומית והביזנטית, והם שהפכו אותה לעיר פסיפסים בין-לאומית. נרשמת &#8211; נכנסת! רישום מראש במערכת תיאום הביקור מבטיח לך מקום באתר ובמועד שאליו נרשמת, ומאפשר קבלת מידע ועדכונים רלוונטיים לביקור המתוכנן. לתיאום ביקור [&hellip;]</p>\\n\",\"filters\":{\"caves_f\":false,\"water_access_f\":false,\"blooming_f\":true,\"archaeology_f\":true,\"viewpoint_f\":false,\"challenging_f\":false,\"easy_f\":true,\"moderate_f\":true,\"accessible_f\":true,\"circular_f\":true,\"linear_f\":false,\"half_day_f\":true,\"full_day_f\":false,\"multi_day_f\":false,\"picnic_f\":true,\"trip_f\":true,\"paid_f\":true,\"not_paid_f\":false,\"free_matmon_f\":true,\"not_map_display\":false}},{\"id\":1912,\"title\":\"שמורת טבע הר מירון\",\"link\":\"https://www.parks.org.il/reserve-park/%d7%a9%d7%9e%d7%95%d7%a8%d7%aa-%d7%98%d7%91%d7%a2-%d7%94%d7%a8-%d7%9e%d7%99%d7%a8%d7%95%d7%9f/\",\"itm_x\":\"238123\",\"itm_y\":\"766996\",\"in_paid\":null,\"image\":\"https://www.parks.org.il/wp-content/uploads/2020/06/תצפית-בהר-מירון-ביום-השני-למסע-צילום-עצמי.jpeg\",\"hours\":{\"Summer_Opening_Hours_s\":\"\",\"Summer_Closing_Hours_s\":\"\",\"Opening_Hours_Summer_Time_Friday\":\"\",\"Closing_Hours_Summer_Time_Friday\":\"\",\"Winter_Opening_Hours_s\":\"\",\"Winter_Closing_Hours_s\":\"\",\"Opening_Hours_Winter_Time_Friday\":\"\",\"Closing_Hours_Winter_Time_Friday\":\"\",\"Opening_hours_of_lifeguard_s\":\"\",\"closing_hours_of_lifeguard_s\":\"\",\"Opening_Tino_On_Pass\":\"\",\"Closing_Time_On_Pas\":\"\",\"Opening_hours_on_Yom_Kippur_s\":\"\",\"closing_hours_on_Yom_Kippur_s\":\"\",\"Special_Opening_hours_s\":\"\",\"Months_of_Beach_activity_s\":\"\",\"Last_entrance_s\":\"\",\"Shop_on_site_s\":\"\"},\"excerpt\":\"<p>שמורת טבע הר מירון היא הגדולה בצפון הארץ. הרים נישאים, חורש סבוך, צמחים ובעלי חיים ייחודיים, מעיינות, מערות ותצפיות נוף לרוב – כל אלה מחכים לכם במרום הגליל.</p>\\n\",\"filters\":{\"caves_f\":false,\"water_access_f\":false,\"blooming_f\":true,\"archaeology_f\":false,\"viewpoint_f\":false,\"challenging_f\":false,\"easy_f\":true,\"moderate_f\":false,\"accessible_f\":false,\"circular_f\":true,\"linear_f\":false,\"half_day_f\":false,\"full_day_f\":false,\"multi_day_f\":false,\"picnic_f\":false,\"trip_f\":true,\"paid_f\":false,\"not_paid_f\":true,\"free_matmon_f\":true,\"not_map_display\":false}},{\"id\":1911,\"title\":\"שמורת טבע נחל עיון (התנור)\",\"link\":\"https://www.parks.org.il/reserve-park/%d7%a9%d7%9e%d7%95%d7%a8%d7%aa-%d7%98%d7%91%d7%a2-%d7%a0%d7%97%d7%9c-%d7%a2%d7%99%d7%95%d7%9f-%d7%94%d7%aa%d7%a0%d7%95%d7%a8/\",\"itm_x\":\"254251\",\"itm_y\":\"797116\",\"in_paid\":null,\"image\":\"https://www.parks.org.il/wp-content/uploads/2017/09/unnamed-file-50.jpg\",\"hours\":{\"Summer_Opening_Hours_s\":\"08:00\",\"Summer_Closing_Hours_s\":\"17:00\",\"Opening_Hours_Summer_Time_Friday\":\"08:00\",\"Closing_Hours_Summer_Time_Friday\":\"16:00\",\"Winter_Opening_Hours_s\":\"08:00\",\"Winter_Closing_Hours_s\":\"16:00\",\"Opening_Hours_Winter_Time_Friday\":\"08:00\",\"Closing_Hours_Winter_Time_Friday\":\"15:00\",\"Opening_hours_of_lifeguard_s\":\"\",\"closing_hours_of_lifeguard_s\":\"\",\"Opening_Tino_On_Pass\":\"08:00\",\"Closing_Time_On_Pas\":\"13:00\",\"Opening_hours_on_Yom_Kippur_s\":\"08:00\",\"closing_hours_on_Yom_Kippur_s\":\"13:00\",\"Special_Opening_hours_s\":\"<h2><strong>שימו לב:</strong></h2>\\n<ul>\\n<li>אם נרשמתם מראש, הגעתם לאתר ואין בו מקום פנוי &#8211; תתבקשו להציג בכניסה לאתר את  האישור על <strong>&quot;תיאום מועד הביקור&quot;</strong> כדי להיכנס.</li>\\n</ul>\\n\",\"Months_of_Beach_activity_s\":\"\",\"Last_entrance_s\":\"הכניסה לשמורת נחל עיון נסגרת שעה לפני השעות הרשומות, המסלול הארוך נסגר שעתיים לפני שעת הסגירה הרשומה.\",\"Shop_on_site_s\":\"\"},\"excerpt\":\"<p>קניון יפהפה, ובו מפלי מים זורמים. לאחר עשרות שנים שבהן היה הנחל יבש בקיץ בשל הטיית המים בלבנון, פעלה רשות הטבע והגנים לחידוש הזרימה בנחל בעזרת מים הנשאבים מנחל דן, כדי לשקם את המערכת האקולוגית הייחודית בנחל עיון. נרשמת &#8211; נכנסת! רישום מראש במערכת תיאום הביקור מבטיח לך מקום בשמורת הטבע נחל עיון במועד שאליו [&hellip;]</p>\\n\",\"filters\":{\"caves_f\":false,\"water_access_f\":true,\"blooming_f\":true,\"archaeology_f\":false,\"viewpoint_f\":true,\"challenging_f\":false,\"easy_f\":true,\"moderate_f\":true,\"accessible_f\":true,\"circular_f\":true,\"linear_f\":true,\"half_day_f\":true,\"full_day_f\":true,\"multi_day_f\":false,\"picnic_f\":true,\"trip_f\":true,\"paid_f\":true,\"not_paid_f\":false,\"free_matmon_f\":true,\"not_map_display\":false}},{\"id\":1910,\"title\":\"שמורת טבע נחל המערות\",\"link\":\"https://www.parks.org.il/reserve-park/%d7%a9%d7%9e%d7%95%d7%a8%d7%aa-%d7%98%d7%91%d7%a2-%d7%a0%d7%97%d7%9c-%d7%94%d7%9e%d7%a2%d7%a8%d7%95%d7%aa/\",\"itm_x\":\"196962\",\"itm_y\":\"730753\",\"in_paid\":null,\"image\":\"https://www.parks.org.il/wp-content/uploads/2017/08/nachal-mearot-e1512901696316.jpg\",\"hours\":{\"Summer_Opening_Hours_s\":\"08:00\",\"Summer_Closing_Hours_s\":\"17:00\",\"Opening_Hours_Summer_Time_Friday\":\"08:00\",\"Closing_Hours_Summer_Time_Friday\":\"16:00\",\"Winter_Opening_Hours_s\":\"08:00\",\"Winter_Closing_Hours_s\":\"16:00\",\"Opening_Hours_Winter_Time_Friday\":\"08:00\",\"Closing_Hours_Winter_Time_Friday\":\"15:00\",\"Opening_hours_of_lifeguard_s\":\"\",\"closing_hours_of_lifeguard_s\":\"\",\"Opening_Tino_On_Pass\":\"08:00\",\"Closing_Time_On_Pas\":\"13:00\",\"Opening_hours_on_Yom_Kippur_s\":\"08:00\",\"closing_hours_on_Yom_Kippur_s\":\"13:00\",\"Special_Opening_hours_s\":\"<h2><strong>שימו לב:</strong></h2>\\n<p>אם נרשמתם מראש, הגעתם לאתר ואין בו מקום פנוי &#8211; תתבקשו להציג בכניסה את האישור על &quot;<strong>תיאום מועד הביקור</strong>&quot; כדי להיכנס.</p>\\n\",\"Months_of_Beach_activity_s\":\"\",\"Last_entrance_s\":\"הכניסה לשמורה נסגרת שעה לפני השעות הרשומות\",\"Shop_on_site_s\":\"\"},\"excerpt\":\"<p>אתר מורשת עולמית חוויה פרהיסטורית במערות שבהן התגוררו בני אדם במשך מאות אלפי שנים, לצד טיולים רגליים קצרים בין מצוקי סלעים, בעולם הטבע העשיר של הר הכרמל. נרשמת &#8211; נכנסת! רישום מראש במערכת תיאום הביקור מבטיח לך מקום באתר ובמועד שאליו נרשמת, ומאפשר קבלת מידע ועדכונים רלוונטיים לביקור המתוכנן. לתיאום ביקור של משפחות/פרטיים  &#8211; לחצו [&hellip;]</p>\\n\",\"filters\":{\"caves_f\":true,\"water_access_f\":false,\"blooming_f\":true,\"archaeology_f\":true,\"viewpoint_f\":true,\"challenging_f\":false,\"easy_f\":true,\"moderate_f\":false,\"accessible_f\":true,\"circular_f\":true,\"linear_f\":false,\"half_day_f\":true,\"full_day_f\":false,\"multi_day_f\":false,\"picnic_f\":true,\"trip_f\":true,\"paid_f\":true,\"not_paid_f\":false,\"free_matmon_f\":true,\"not_map_display\":false}},{\"id\":1908,\"title\":\"שמורת טבע גלבוע\",\"link\":\"https://www.parks.org.il/reserve-park/%d7%a9%d7%9e%d7%95%d7%a8%d7%aa-%d7%98%d7%91%d7%a2-%d7%92%d7%9c%d7%91%d7%95%d7%a2/\",\"itm_x\":\"240288\",\"itm_y\":\"710523\",\"in_paid\":null,\"image\":\"https://www.parks.org.il/wp-content/uploads/2018/06/5b61890db1b92-e1533200549734.jpg\",\"hours\":{\"Summer_Opening_Hours_s\":\"\",\"Summer_Closing_Hours_s\":\"\",\"Opening_Hours_Summer_Time_Friday\":\"\",\"Closing_Hours_Summer_Time_Friday\":\"\",\"Winter_Opening_Hours_s\":\"\",\"Winter_Closing_Hours_s\":\"\",\"Opening_Hours_Winter_Time_Friday\":\"\",\"Closing_Hours_Winter_Time_Friday\":\"\",\"Opening_hours_of_lifeguard_s\":\"\",\"closing_hours_of_lifeguard_s\":\"\",\"Opening_Tino_On_Pass\":\"\",\"Closing_Time_On_Pas\":\"\",\"Opening_hours_on_Yom_Kippur_s\":\"\",\"closing_hours_on_Yom_Kippur_s\":\"\",\"Special_Opening_hours_s\":\"\",\"Months_of_Beach_activity_s\":\"\",\"Last_entrance_s\":\"\",\"Shop_on_site_s\":\"\"},\"excerpt\":\"<p>שמורת טבע גלבוע נמצאת במדרון ההר, המתנשא זקוף מעל עמק חרוד ובקעת בית שאן. אל הגלבוע  באים כדי ליהנות ממראה אירוס הגלבוע ומהפריחה השופעת באביב, כדי לטייל במסלולי הטיול היפים שבו ולצפות בנופים המרהיבים הנראים מפסגותיו</p>\\n\",\"filters\":{\"caves_f\":false,\"water_access_f\":false,\"blooming_f\":true,\"archaeology_f\":true,\"viewpoint_f\":false,\"challenging_f\":false,\"easy_f\":true,\"moderate_f\":true,\"accessible_f\":false,\"circular_f\":true,\"linear_f\":false,\"half_day_f\":false,\"full_day_f\":false,\"multi_day_f\":false,\"picnic_f\":false,\"trip_f\":true,\"paid_f\":false,\"not_paid_f\":true,\"free_matmon_f\":true,\"not_map_display\":false}},{\"id\":1907,\"title\":\"גן לאומי תל חצור\",\"link\":\"https://www.parks.org.il/reserve-park/%d7%92%d7%9f-%d7%9c%d7%90%d7%95%d7%9e%d7%99-%d7%aa%d7%9c-%d7%97%d7%a6%d7%95%d7%a8/\",\"itm_x\":\"253613\",\"itm_y\":\"769325\",\"in_paid\":null,\"image\":\"https://www.parks.org.il/wp-content/uploads/2017/09/tel-chazor-doron-nisim-compressed.jpg\",\"hours\":{\"Summer_Opening_Hours_s\":\"08:00\",\"Summer_Closing_Hours_s\":\"17:00\",\"Opening_Hours_Summer_Time_Friday\":\"08:00\",\"Closing_Hours_Summer_Time_Friday\":\"16:00\",\"Winter_Opening_Hours_s\":\"08:00\",\"Winter_Closing_Hours_s\":\"16:00\",\"Opening_Hours_Winter_Time_Friday\":\"08:00\",\"Closing_Hours_Winter_Time_Friday\":\"15:00\",\"Opening_hours_of_lifeguard_s\":\"\",\"closing_hours_of_lifeguard_s\":\"\",\"Opening_Tino_On_Pass\":\"08:00\",\"Closing_Time_On_Pas\":\"13:00\",\"Opening_hours_on_Yom_Kippur_s\":\"08:00\",\"closing_hours_on_Yom_Kippur_s\":\"13:00\",\"Special_Opening_hours_s\":\"<h2><strong>שימו לב:</strong></h2>\\n<p>אם נרשמתם מראש, הגעתם לאתר ואין בו מקום פנוי &#8211; תתבקשו להציג בכניסה את האישור על &quot;<strong>תיאום מועד הביקור</strong>&quot; כדי להיכנס.</p>\\n\",\"Months_of_Beach_activity_s\":\"\",\"Last_entrance_s\":\"הכניסה לגן נסגרת שעה לפני השעות הרשומות\",\"Shop_on_site_s\":\"\"},\"excerpt\":\"<p>תל חצור אתר מורשת עולמית המזוהה עם חצור המקראית – אולי הגדולה בערי ארץ ישראל בתקופה הכנענית המאוחרת. עם הממצאים החשובים נמנים מפעל מים מרשים מאין כמוהו, ארמון כנעני, ומבנים מהתקופה הישראלית הקדומה. &nbsp; נרשמת &#8211; נכנסת! רישום מראש במערכת תיאום הביקור מבטיח לך מקום באתר ובמועד שאליו נרשמת, ומאפשר קבלת מידע ועדכונים רלוונטיים לביקור [&hellip;]</p>\\n\",\"filters\":{\"caves_f\":false,\"water_access_f\":false,\"blooming_f\":true,\"archaeology_f\":true,\"viewpoint_f\":true,\"challenging_f\":false,\"easy_f\":true,\"moderate_f\":false,\"accessible_f\":true,\"circular_f\":true,\"linear_f\":false,\"half_day_f\":true,\"full_day_f\":false,\"multi_day_f\":false,\"picnic_f\":true,\"trip_f\":true,\"paid_f\":true,\"not_paid_f\":false,\"free_matmon_f\":true,\"not_map_display\":false}},{\"id\":1906,\"title\":\"גן לאומי יודפת העתיקה\",\"link\":\"https://www.parks.org.il/reserve-park/%d7%92%d7%9f-%d7%9c%d7%90%d7%95%d7%9e%d7%99-%d7%99%d7%95%d7%93%d7%a4%d7%aa-%d7%94%d7%a2%d7%aa%d7%99%d7%a7%d7%94/\",\"itm_x\":\"226322\",\"itm_y\":\"748786\",\"in_paid\":null,\"image\":\"https://www.parks.org.il/wp-content/uploads/2017/09/2-4.jpg\",\"hours\":{\"Summer_Opening_Hours_s\":\"\",\"Summer_Closing_Hours_s\":\"\",\"Opening_Hours_Summer_Time_Friday\":\"\",\"Closing_Hours_Summer_Time_Friday\":\"\",\"Winter_Opening_Hours_s\":\"\",\"Winter_Closing_Hours_s\":\"\",\"Opening_Hours_Winter_Time_Friday\":\"\",\"Closing_Hours_Winter_Time_Friday\":\"\",\"Opening_hours_of_lifeguard_s\":\"\",\"closing_hours_of_lifeguard_s\":\"\",\"Opening_Tino_On_Pass\":\"\",\"Closing_Time_On_Pas\":\"\",\"Opening_hours_on_Yom_Kippur_s\":\"\",\"closing_hours_on_Yom_Kippur_s\":\"\",\"Special_Opening_hours_s\":\"\",\"Months_of_Beach_activity_s\":\"\",\"Last_entrance_s\":\"\",\"Shop_on_site_s\":\"\"},\"excerpt\":\"<p>ביודפת נחשפים השרידים המרגשים של העיר שמרדה ברומאים והחזיקה מעמד נגד חילותיו של אספסיאנוס במשך 47 ימים של לחימה אכזרית. בספטמבר פורחים כאן עשרות אלפי חצבים ואפשר גם ליהנות מהממדים יוצאי הדופן של עצי הלבנה שבמקום</p>\\n\",\"filters\":{\"caves_f\":false,\"water_access_f\":false,\"blooming_f\":false,\"archaeology_f\":true,\"viewpoint_f\":false,\"challenging_f\":false,\"easy_f\":true,\"moderate_f\":true,\"accessible_f\":false,\"circular_f\":true,\"linear_f\":false,\"half_day_f\":true,\"full_day_f\":true,\"multi_day_f\":false,\"picnic_f\":false,\"trip_f\":true,\"paid_f\":false,\"not_paid_f\":true,\"free_matmon_f\":true,\"not_map_display\":false}},{\"id\":1905,\"title\":\"גן לאומי ושמורת טבע ארבל\",\"link\":\"https://www.parks.org.il/reserve-park/arbel/\",\"itm_x\":\"246654\",\"itm_y\":\"747464\",\"in_paid\":null,\"image\":\"https://www.parks.org.il/wp-content/uploads/2017/10/arbel_2012_1-e1512900771516.jpg\",\"hours\":{\"Summer_Opening_Hours_s\":\"08:00\",\"Summer_Closing_Hours_s\":\"17:00\",\"Opening_Hours_Summer_Time_Friday\":\"08:00\",\"Closing_Hours_Summer_Time_Friday\":\"16:00\",\"Winter_Opening_Hours_s\":\"08:00\",\"Winter_Closing_Hours_s\":\"16:00\",\"Opening_Hours_Winter_Time_Friday\":\"08:00\",\"Closing_Hours_Winter_Time_Friday\":\"15:00\",\"Opening_hours_of_lifeguard_s\":\"\",\"closing_hours_of_lifeguard_s\":\"\",\"Opening_Tino_On_Pass\":\"08:00\",\"Closing_Time_On_Pas\":\"13:00\",\"Opening_hours_on_Yom_Kippur_s\":\"08:00\",\"closing_hours_on_Yom_Kippur_s\":\"13:00\",\"Special_Opening_hours_s\":\"<p>&nbsp;</p>\\n<p><strong>שימו לב:</strong> אם נרשמתם מראש, הגעתם לאתר ואין בו מקום פנוי &#8211; תתבקשו להציג בכניסה את האישור על &quot;<strong>תיאום מועד הביקור</strong>&quot; כדי להיכנס.</p>\\n<p>&nbsp;</p>\\n\",\"Months_of_Beach_activity_s\":\"\",\"Last_entrance_s\":\"הכניסה לאתר נסגרת שעה לפני שעות הסגירה הרשומות. כניסה אחרונה למסלולים היורדים את המצוק שלוש שעות לפני סגירת האתר, כניסה לתצפיות שעה לפני סגירת האתר.\",\"Shop_on_site_s\":\"\"},\"excerpt\":\"<p>מצוק הארבל, המתנוסס מעל הכנרת, משקיף לגולן לחרמון ולהרי הגליל ומהווה את לבה של שמורת הטבע ארבל, ואת הגן הלאומי ארבל המקיף אותה. הגן הלאומי ושמורת טבע ארבל כוללים גם את הר ניתאי, הר סביון, נחל ארבל וכן שני יישובים קדומים שהותירו שרידי שני בתי כנסת מפוארים וחומה מימי המרד הגדול, וכן שבילי טיול אל [&hellip;]</p>\\n\",\"filters\":{\"caves_f\":true,\"water_access_f\":false,\"blooming_f\":true,\"archaeology_f\":true,\"viewpoint_f\":true,\"challenging_f\":true,\"easy_f\":true,\"moderate_f\":true,\"accessible_f\":true,\"circular_f\":true,\"linear_f\":true,\"half_day_f\":true,\"full_day_f\":true,\"multi_day_f\":false,\"picnic_f\":true,\"trip_f\":true,\"paid_f\":true,\"not_paid_f\":false,\"free_matmon_f\":true,\"not_map_display\":false}},{\"id\":1904,\"title\":\"שמורת טבע החולה\",\"link\":\"https://www.parks.org.il/reserve-park/%d7%a9%d7%9e%d7%95%d7%a8%d7%aa-%d7%98%d7%91%d7%a2-%d7%94%d7%97%d7%95%d7%9c%d7%94/\",\"itm_x\":\"255594\",\"itm_y\":\"775667\",\"in_paid\":null,\"image\":\"https://www.parks.org.il/wp-content/uploads/2017/09/shmurat-achula-doron-nisim-3-compressed-e1527164444396.jpg\",\"hours\":{\"Summer_Opening_Hours_s\":\"08:00\",\"Summer_Closing_Hours_s\":\"17:00\",\"Opening_Hours_Summer_Time_Friday\":\"08:00\",\"Closing_Hours_Summer_Time_Friday\":\"16:00\",\"Winter_Opening_Hours_s\":\"08:00\",\"Winter_Closing_Hours_s\":\"16:00\",\"Opening_Hours_Winter_Time_Friday\":\"08:00\",\"Closing_Hours_Winter_Time_Friday\":\"15:00\",\"Opening_hours_of_lifeguard_s\":\"\",\"closing_hours_of_lifeguard_s\":\"\",\"Opening_Tino_On_Pass\":\"08:00\",\"Closing_Time_On_Pas\":\"13:00\",\"Opening_hours_on_Yom_Kippur_s\":\"08:00\",\"closing_hours_on_Yom_Kippur_s\":\"13:00\",\"Special_Opening_hours_s\":\"<p><strong>בחג ובחול המועד סוכות:</strong> אין שינוי בשעות הפעילות</p>\\n<p><strong>שימו לב:</strong> אם נרשמתם מראש, הגעתם לאתר ואין בו מקום פנוי &#8211; תתבקשו להציג בכניסה את האישור על &quot;<strong>תיאום מועד הביקור</strong>&quot; כדי להיכנס.</p>\\n\",\"Months_of_Beach_activity_s\":\"\",\"Last_entrance_s\":\"הכניסה לגן נסגרת שעה לפני השעות הרשומות\",\"Shop_on_site_s\":\"\"},\"excerpt\":\"<p>אתר בעל חשיבות עולמית לעופות מים ובית גידול לח חשוב ביותר במזרח התיכון. כאן הכול התחיל&#8230; המאבק להצלת ביצת החולה החל בשנות ה-50 של המאה העשרים והוביל להקמתה של שמורת הטבע הראשונה בישראל. מאז עברה השמורה תהליכי שיקום נרחבים. נרשמת &#8211; נכנסת! רישום מראש במערכת תיאום הביקור מבטיח לך מקום באתר ובמועד שאליו נרשמת, ומאפשר [&hellip;]</p>\\n\",\"filters\":{\"caves_f\":false,\"water_access_f\":false,\"blooming_f\":true,\"archaeology_f\":false,\"viewpoint_f\":false,\"challenging_f\":false,\"easy_f\":true,\"moderate_f\":false,\"accessible_f\":true,\"circular_f\":true,\"linear_f\":false,\"half_day_f\":true,\"full_day_f\":false,\"multi_day_f\":false,\"picnic_f\":true,\"trip_f\":true,\"paid_f\":true,\"not_paid_f\":false,\"free_matmon_f\":true,\"not_map_display\":false}},{\"id\":1903,\"title\":\"שמורת טבע עין אפק\",\"link\":\"https://www.parks.org.il/reserve-park/%d7%a9%d7%9e%d7%95%d7%a8%d7%aa-%d7%98%d7%91%d7%a2-%d7%a2%d7%99%d7%9f-%d7%90%d7%a4%d7%a7/\",\"itm_x\":\"210807\",\"itm_y\":\"750283\",\"in_paid\":null,\"image\":\"https://www.parks.org.il/wp-content/uploads/2017/08/DSC_8687-e1512574029824.jpg\",\"hours\":{\"Summer_Opening_Hours_s\":\"08:00\",\"Summer_Closing_Hours_s\":\"17:00\",\"Opening_Hours_Summer_Time_Friday\":\"08:00\",\"Closing_Hours_Summer_Time_Friday\":\"16:00\",\"Winter_Opening_Hours_s\":\"08:00\",\"Winter_Closing_Hours_s\":\"16:00\",\"Opening_Hours_Winter_Time_Friday\":\"08:00\",\"Closing_Hours_Winter_Time_Friday\":\"15:00\",\"Opening_hours_of_lifeguard_s\":\"\",\"closing_hours_of_lifeguard_s\":\"\",\"Opening_Tino_On_Pass\":\"08:00\",\"Closing_Time_On_Pas\":\"13:00\",\"Opening_hours_on_Yom_Kippur_s\":\"08:00\",\"closing_hours_on_Yom_Kippur_s\":\"13:00\",\"Special_Opening_hours_s\":\"<h2>שימו לב</h2>\\n<ul>\\n<li>הדלקת אש בשמורה אסורה בהחלט, כולל שימוש במנגלים.</li>\\n<li>אם נרשמתם מראש, הגעתם לאתר ואין בו מקום פנוי &#8211; תתבקשו להציג בכניסה את האישור על &quot;<strong>תיאום מועד הביקור</strong>&quot; כדי להיכנס.</li>\\n</ul>\\n\",\"Months_of_Beach_activity_s\":\"\",\"Last_entrance_s\":\"הכניסה לשמורה נסגרת שעה לפני השעות הרשומות\",\"Shop_on_site_s\":\"\"},\"excerpt\":\"<p>שמורת הטבע עין אפק משמרת נופי ביצה ומקורות נחל שרובם אבדו מן הארץ. בשביל הביצה שבשמורה הולכים המטיילים מעל ביצה מוקפת בצמחיית גדות עשירה ועופות מים ססגוניים. מראש טחנת הקמח העתיקה נראים נופי עמק עכו, ובגן המקלט אפשר להתרשם מהצמחים הנדירים של מישור החוף. נרשמת &#8211; נכנסת! רישום מראש במערכת תיאום הביקור מבטיח לך מקום [&hellip;]</p>\\n\",\"filters\":{\"caves_f\":false,\"water_access_f\":false,\"blooming_f\":true,\"archaeology_f\":true,\"viewpoint_f\":false,\"challenging_f\":false,\"easy_f\":true,\"moderate_f\":false,\"accessible_f\":true,\"circular_f\":true,\"linear_f\":false,\"half_day_f\":true,\"full_day_f\":false,\"multi_day_f\":false,\"picnic_f\":true,\"trip_f\":true,\"paid_f\":true,\"not_paid_f\":false,\"free_matmon_f\":true,\"not_map_display\":false}},{\"id\":1902,\"title\":\"שמורת טבע גמלא\",\"link\":\"https://www.parks.org.il/reserve-park/%d7%a9%d7%9e%d7%95%d7%a8%d7%aa-%d7%98%d7%91%d7%a2-%d7%92%d7%9e%d7%9c%d7%90/\",\"itm_x\":\"270248\",\"itm_y\":\"756885\",\"in_paid\":null,\"image\":\"https://www.parks.org.il/wp-content/uploads/2017/09/1-5-e1512547855479.jpg\",\"hours\":{\"Summer_Opening_Hours_s\":\"08:00\",\"Summer_Closing_Hours_s\":\"17:00\",\"Opening_Hours_Summer_Time_Friday\":\"08:00\",\"Closing_Hours_Summer_Time_Friday\":\"16:00\",\"Winter_Opening_Hours_s\":\"08:00\",\"Winter_Closing_Hours_s\":\"16:00\",\"Opening_Hours_Winter_Time_Friday\":\"08:00\",\"Closing_Hours_Winter_Time_Friday\":\"15:00\",\"Opening_hours_of_lifeguard_s\":\"\",\"closing_hours_of_lifeguard_s\":\"\",\"Opening_Tino_On_Pass\":\"08:00\",\"Closing_Time_On_Pas\":\"13:00\",\"Opening_hours_on_Yom_Kippur_s\":\"08:00\",\"closing_hours_on_Yom_Kippur_s\":\"13:00\",\"Special_Opening_hours_s\":\"<p><strong>בחג ובחול המועד סוכות: </strong>אין שינוי בשעות הפעילות</p>\\n<h4><strong>⚠ שימו לב: </strong></h4>\\n<ul>\\n<li>כביש הגישה לעיר גמלא סגור בשל בעיות בטיחות. ההגעה לעיר רגלית דרך השמורה.</li>\\n<li><strong>הכניסה לאתר נסגרת שעה לפני שעות הסגירה הרשומות. </strong></li>\\n<li><strong>למסלולים הבאים ניתן להיכנס לפי המפורט כאן:</strong>\\n<ul>\\n<li><strong>למפל</strong> &#8211; עד שעתיים לפני סגירת האתר.</li>\\n<li><strong>לנחל דליות</strong> &#8211; עד שלוש שעות לפני סגירת האתר.</li>\\n<li><strong>לעיר העתיקה </strong>&#8211; שלוש שעות לפני סגירת האתר.</li>\\n<li><strong>למסלול התצפיות</strong> &#8211; שעה לפני סגירת האתר.</li>\\n</ul>\\n</li>\\n<li>אם נרשמתם מראש, הגעתם לאתר ואין בו מקום פנוי &#8211; תתבקשו להציג בכניסה את האישור על &quot;<strong>תיאום מועד הביקור</strong>&quot; כדי להיכנס.</li>\\n</ul>\\n\",\"Months_of_Beach_activity_s\":\"\",\"Last_entrance_s\":\"הכניסה לשמורה נסגרת שעה לפני השעות הרשומות\",\"Shop_on_site_s\":\"\"},\"excerpt\":\"<p>שילוב נדיר של טבע ונוף עם סיפור אנושי היסטורי מרתק. המצפור צופה אל מושבת קינון של עופות דורסים, ובמרחק הליכה ממנו, בראש קניוני הנחלים המרשימים – שרידיה של העיר העתיקה גמלא, המספרים את סיפור גבורתה הייחודי, ובהם שרידי בית הכנסת הקדום ביותר בעולם. שימו לב: במקום מתבצעות עבודות פיתוח לחידוש מבואת הכניסה ומרכז מבקרים חדש. [&hellip;]</p>\\n\",\"filters\":{\"caves_f\":false,\"water_access_f\":false,\"blooming_f\":true,\"archaeology_f\":true,\"viewpoint_f\":true,\"challenging_f\":true,\"easy_f\":true,\"moderate_f\":false,\"accessible_f\":true,\"circular_f\":true,\"linear_f\":false,\"half_day_f\":true,\"full_day_f\":false,\"multi_day_f\":false,\"picnic_f\":true,\"trip_f\":true,\"paid_f\":true,\"not_paid_f\":false,\"free_matmon_f\":true,\"not_map_display\":false}},{\"id\":1899,\"title\":\"שמורת טבע נחל עמוד\",\"link\":\"https://www.parks.org.il/reserve-park/%d7%a9%d7%9e%d7%95%d7%a8%d7%aa-%d7%98%d7%91%d7%a2-%d7%a0%d7%97%d7%9c-%d7%a2%d7%9e%d7%95%d7%93/\",\"itm_x\":\"247123\",\"itm_y\":\"754666\",\"in_paid\":null,\"image\":\"https://www.parks.org.il/wp-content/uploads/2017/08/nachal-amud-e1512889142805.jpg\",\"hours\":{\"Summer_Opening_Hours_s\":\"\",\"Summer_Closing_Hours_s\":\"\",\"Opening_Hours_Summer_Time_Friday\":\"\",\"Closing_Hours_Summer_Time_Friday\":\"\",\"Winter_Opening_Hours_s\":\"\",\"Winter_Closing_Hours_s\":\"\",\"Opening_Hours_Winter_Time_Friday\":\"\",\"Closing_Hours_Winter_Time_Friday\":\"\",\"Open