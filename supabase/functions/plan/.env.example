# Provider config for the LLM trip-planner Edge Function (vendor-agnostic,
# OpenAI-compatible). This .example ships NAMES ONLY — never commit real values.
#
# Set the real values as Supabase secrets (NOT in the repo):
#   cp supabase/functions/plan/.env.example supabase/functions/plan/.env
#   # edit .env with real values, then:
#   supabase secrets set --env-file supabase/functions/plan/.env
# (.env with real values must stay gitignored.)
#
# Any OpenAI-compatible provider works — swap these three vars, no code change:
#   NVIDIA NIM : LLM_BASE_URL=https://integrate.api.nvidia.com/v1   (key prefix: nvapi-)
#   Groq / OpenRouter / Together / local Ollama also expose /v1/chat/completions.

LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=

# NOTE: SUPABASE_URL and the public anon key are NOT secrets — they live in
# index.html (public by design). Only the three vars above belong in Supabase.
